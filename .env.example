# URL de l’API Express (suffixe /api recommandé)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Lancement sept. 2026 : laisser false (ou absent) pour masquer PA / Factur-X / réception in-app.
# NEXT_PUBLIC_FEATURES_EINVOICE=true quand connecteur PA prêt (~2027 TPE).

# Sélecteur FR/EN masqué par défaut — interface en français. true pour réafficher le toggle.
# NEXT_PUBLIC_SHOW_LOCALE_SWITCHER=false

# Pages légales — société Nexiora, marque SoftFacture France
NEXT_PUBLIC_LEGAL_BRAND=SoftFacture France
NEXT_PUBLIC_LEGAL_COMPANY_NAME=Nexiora
NEXT_PUBLIC_LEGAL_LEGAL_FORM=SAS
NEXT_PUBLIC_LEGAL_ADDRESS_LINE1=10 rue Example
NEXT_PUBLIC_LEGAL_ADDRESS_LINE2=75001 Paris
NEXT_PUBLIC_LEGAL_SIRET=00000000000000
NEXT_PUBLIC_LEGAL_VAT=FR00000000000
NEXT_PUBLIC_LEGAL_RCS=Paris B 000 000 000
NEXT_PUBLIC_LEGAL_CAPITAL=1 000 €
NEXT_PUBLIC_LEGAL_DIRECTOR=Nom Prénom
NEXT_PUBLIC_LEGAL_EMAIL=contact@softfacture.fr
# Optionnel — délégué à la protection des données (sinon = LEGAL_EMAIL)
NEXT_PUBLIC_LEGAL_DPO_EMAIL=
NEXT_PUBLIC_LEGAL_HOST_NAME=Vercel / OVH / autre
NEXT_PUBLIC_LEGAL_HOST_ADDRESS=Adresse de l'hébergeur

# Base de données Next (schéma local / marketing) — optionnel si vous n’utilisez que l’API
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/softfacture?schema=public"
