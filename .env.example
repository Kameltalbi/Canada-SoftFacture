# URL de l’API Express (suffixe /api recommandé)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Factur-X / e-facture désactivé pour le Canada (aucune obligation B2B en vigueur).
# Laisser commenté. Décommenter uniquement si un connecteur PA canadien est disponible.
# NEXT_PUBLIC_FEATURES_EINVOICE=true

# Sélecteur FR/EN — activer pour afficher le toggle de langue (recommandé pour le Canada).
NEXT_PUBLIC_SHOW_LOCALE_SWITCHER=true

# Pages légales — société Nexiora Inc., marque SoftFacture Canada
NEXT_PUBLIC_LEGAL_BRAND=SoftFacture Canada
NEXT_PUBLIC_LEGAL_COMPANY_NAME=Nexiora Inc.
NEXT_PUBLIC_LEGAL_LEGAL_FORM=Inc.
NEXT_PUBLIC_LEGAL_ADDRESS_LINE1=123 rue Exemple
NEXT_PUBLIC_LEGAL_ADDRESS_LINE2=Montréal, QC  H2X 1Y1
NEXT_PUBLIC_LEGAL_SIRET=0000000000
NEXT_PUBLIC_LEGAL_VAT=123456789 RT0001
NEXT_PUBLIC_LEGAL_RCS=NEQ : 1234567890
NEXT_PUBLIC_LEGAL_CAPITAL=
NEXT_PUBLIC_LEGAL_DIRECTOR=Prénom Nom
NEXT_PUBLIC_LEGAL_EMAIL=contact@softfacture.ca
# Optionnel — responsable de la protection des renseignements personnels (sinon = LEGAL_EMAIL)
NEXT_PUBLIC_LEGAL_DPO_EMAIL=
NEXT_PUBLIC_LEGAL_HOST_NAME=AWS / Azure / autre hébergeur en Amérique du Nord
NEXT_PUBLIC_LEGAL_HOST_ADDRESS=Adresse de l'hébergeur

# Base de données Next (schéma local / marketing) — optionnel si vous n’utilisez que l’API
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/softfacture?schema=public"
