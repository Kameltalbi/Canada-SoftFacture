# Adapter le nom de la base (dernier segment du chemin). Elle doit exister sur le serveur :
#   npm run db:create
# ou : createdb softfacture_api   (psql / Postgres.app)
DATABASE_URL=

# ── Loi 25 / PIPEDA — Chiffrement des champs sensibles (AES-256-GCM) ──────────
# Générer avec : openssl rand -hex 32
# OBLIGATOIRE en production. Sans cette clé, les champs email/phone des clients
# ne seront pas chiffrés au repos (violation de la Loi 25 art. 10).
FIELD_ENCRYPTION_KEY=

# Salt pour la recherche par hash déterministe (email → sha256 pour la recherche)
# Générer avec : openssl rand -hex 24
SEARCH_HASH_SALT=softfacture-ca-loi25-changeme
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/softfacture_api?schema=public"
JWT_SECRET="change-me-minimum-32-characters-long-secret"
PORT=4000
# Origines autorisées (séparées par des virgules). FRONTEND_URL est un alias pratique.
# En dev, Next peut utiliser 3000, 3001, 3002… (tout localhost est accepté si NODE_ENV !== production)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002"
FRONTEND_URL="http://localhost:3000"

# Lancement sept. 2026 : laisser false (ou absent) — désactive API réception + webhooks PA.
# FEATURES_EINVOICE=true pour activer received-invoices et /api/webhooks/pa
# FEATURES_EINVOICE=false

# ─── Abonnements / Stripe (France, EUR TTC) ───
# Laisser vide en dev : le checkout enregistre l'offre et active l'essai sans redirection.
# Clés test : https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Optionnel : Price IDs Dashboard (sinon les montants TTC de /tarifs sont envoyés à Stripe)
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""
# Tarifs affichés en HT : laisser true pour ajouter la TVA au paiement (Stripe Tax requis sur le compte)
STRIPE_AUTOMATIC_TAX=true
# Webhook local : stripe listen --forward-to localhost:4000/api/billing/webhooks/stripe

# ─── TunTrust DIGIGO (Signature électronique) ───
# Optionnel — laisser vide pour désactiver la signature électronique
TUNTRUST_API_URL=""
TUNTRUST_CLIENT_ID=""
TUNTRUST_CLIENT_SECRET=""
TUNTRUST_API_KEY=""
TUNTRUST_CALLBACK_URL="http://localhost:4000/api/signatures/callback"
