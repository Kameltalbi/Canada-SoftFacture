    "faq": {
      "title": "Frequently asked questions",
      "cancel": {
        "q": "Can I cancel at any time?",
        "a": "Yes, with no fees or penalties. You can cancel your subscription at any time from your dashboard. Your access remains active until the end of the current billing period."
      },
      "hidden": {
        "q": "Are there any hidden fees?",
        "a": "No. The displayed price is the only amount charged, plus applicable taxes (GST 5% + QST 9.975% in Quebec). No setup fees or mandatory add-ons."
      },
      "hosting": {
        "q": "Is my data hosted in Canada?",
        "a": "Yes. All your infrastructure — databases, backups and servers — is physically hosted in Quebec, Canada, in compliance with Law 25 requirements."
      },
      "taxes": {
        "q": "Are GST / HST / PST taxes handled?",
        "a": "Yes. Softfacture automatically calculates and applies federal GST (5%), Quebec QST (9.975%), HST and other provincial taxes based on your business and client profiles."
      },
      "import": {
        "q": "Can I import my existing clients?",
        "a": "Yes. You can import your client list via a CSV file from your dashboard, or use our API (Expert plan) for automated integration."
      },
      "upgrade": {
        "q": "Can I switch plans at any time?",
        "a": "Yes. You can upgrade or downgrade at any time. The price difference is calculated pro-rata for the remaining period."
      }
    },
    "finalCta": {
      "title": "Ready to simplify your invoicing?",
      "subtitle": "Join thousands of Canadian entrepreneurs. 30-day free trial, no credit card required.",
      "cta": "Start for free"
    }
